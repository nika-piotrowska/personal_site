<section class="page-section">
  <p class="section-label"><%= t("pages.contact.label") %></p>
  <h1><%= t("pages.contact.title") %></h1>

  <div class="content-card">
    <p class="page-intro">
      <%= t("pages.contact.intro") %>
    </p>

    <div class="contact-list">
      <% if @profile.email.present? %>
        <div class="contact-item">
          <span><%= t("pages.contact.email") %></span>
          <%= mail_to @profile.email %>
        </div>
      <% end %>

      <% if @profile.github_url.present? %>
        <div class="contact-item">
          <span><%= t("pages.contact.github") %></span>
          <%= external_link_to(@profile.github_url) %>
        </div>
      <% end %>

      <% if @profile.linkedin_url.present? %>
        <div class="contact-item">
          <span><%= t("pages.contact.linkedin") %></span>
          <%= external_link_to(@profile.linkedin_url) %>
        </div>
      <% end %>
    </div>
  </div>
</section>
