<div class="d-flex justify-content-between align-items-center mb-4">
  <div>
    <h2 class="mb-1">Profile</h2>
    <p class="text-muted mb-0">Preview of your profile data.</p>
  </div>

  <%= link_to 'Edit profile', edit_admin_profile_path, class: 'btn btn-primary' %>
</div>

<div class="card">
  <div class="card-body">
    <dl class="row mb-0">
      <dt class="col-sm-3">Full name</dt>
      <dd class="col-sm-9">Weronika Piotrowska</dd>

      <dt class="col-sm-3">Headline</dt>
      <dd class="col-sm-9">Ruby on Rails Developer</dd>

      <dt class="col-sm-3">Location</dt>
      <dd class="col-sm-9">Poland</dd>

      <dt class="col-sm-3">Email</dt>
      <dd class="col-sm-9">weronika@example.com</dd>

      <dt class="col-sm-3">Bio</dt>
      <dd class="col-sm-9">
        Short professional bio placeholder for admin preview.
      </dd>
    </dl>
  </div>
</div>
