<div class="admin-page-header">
  <div>
    <h2 class="admin-page-header__title">Profile</h2>
    <p class="admin-page-header__description">
      Manage your personal information displayed on the portfolio website.
    </p>
  </div>

  <div>
    <% if @profile.present? %>
      <%= link_to "Edit profile", edit_admin_profile_path, class: "admin-button admin-button--primary" %>
    <% end %>
  </div>
</div>

<% if @profile.present? %>
  <div class="admin-card">
    <div class="admin-card__body">
      <dl class="admin-details">
        <div class="admin-details__row">
          <dt>Headline</dt>
          <dd><%= @profile.headline.presence || "—" %></dd>
        </div>

        <div class="admin-details__row">
          <dt>Email</dt>
          <dd><%= @profile.email.presence || "—" %></dd>
        </div>

        <div class="admin-details__row">
          <dt>Location</dt>
          <dd><%= @profile.location.presence || "—" %></dd>
        </div>

        <div class="admin-details__row">
          <dt>LinkedIn</dt>
          <dd>
            <% if @profile.linkedin_url.present? %>
              <%= link_to @profile.linkedin_url, @profile.linkedin_url, target: "_blank", rel: "noopener" %>
            <% else %>
              —
            <% end %>
          </dd>
        </div>

        <div class="admin-details__row">
          <dt>GitHub</dt>
          <dd>
            <% if @profile.github_url.present? %>
              <%= link_to @profile.github_url, @profile.github_url, target: "_blank", rel: "noopener" %>
            <% else %>
              —
            <% end %>
          </dd>
        </div>

        <div class="admin-details__row admin-details__row--stacked">
          <dt>Bio</dt>
          <dd><%= simple_format(@profile.bio.presence || "—") %></dd>
        </div>
      </dl>
    </div>
  </div>
<% else %>
  <div class="admin-card">
    <div class="admin-card__body">
      <p>You have not created your profile yet.</p>

      <%= link_to "Create profile", new_admin_profile_path, class: "admin-button admin-button--primary" %>
    </div>
  </div>
<% end %>
