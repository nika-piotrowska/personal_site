<div class="admin-page-header">
  <div>
    <h2 class="admin-page-header__title"><%= t(".title") %></h2>
    <p class="admin-page-header__description">
      <%= t(".description") %>
    </p>
  </div>

  <div>
    <% if @profile.present? %>
      <%= link_to t(".edit"), edit_admin_profile_path, class: "admin-button admin-button--primary" %>
    <% end %>
  </div>
</div>

<% if @profile.present? %>
  <div class="admin-card">
    <div class="admin-card__body">
      <dl class="admin-details">
        <div class="admin-details__row">
          <dt><%= Profile.human_attribute_name(:headline) %></dt>
          <dd><%= @profile.headline.presence || t("common.none") %></dd>
        </div>

        <div class="admin-details__row">
          <dt><%= Profile.human_attribute_name(:email) %></dt>
          <dd><%= @profile.email.presence || t("common.none") %></dd>
        </div>

        <div class="admin-details__row">
          <dt><%= Profile.human_attribute_name(:location) %></dt>
          <dd><%= @profile.location.presence || t("common.none") %></dd>
        </div>

        <div class="admin-details__row">
          <dt><%= Profile.human_attribute_name(:linkedin_url) %></dt>
          <dd>
            <% if @profile.linkedin_url.present? %>
              <%= link_to @profile.linkedin_url, @profile.linkedin_url, target: "_blank", rel: "noopener" %>
            <% else %>
              <%= t("common.none") %>
            <% end %>
          </dd>
        </div>

        <div class="admin-details__row">
          <dt><%= Profile.human_attribute_name(:github_url) %></dt>
          <dd>
            <% if @profile.github_url.present? %>
              <%= link_to @profile.github_url, @profile.github_url, target: "_blank", rel: "noopener" %>
            <% else %>
              <%= t("common.none") %>
            <% end %>
          </dd>
        </div>

        <div class="admin-details__row admin-details__row--stacked">
          <dt><%= Profile.human_attribute_name(:bio) %></dt>
          <dd><%= simple_format(@profile.bio.presence || t("common.none")) %></dd>
        </div>
      </dl>
    </div>
  </div>
<% else %>
  <div class="admin-card">
    <div class="admin-card__body">
      <p><%= t(".empty") %></p>
      <%= link_to t("common.create_profile"), new_admin_profile_path, class: "admin-button admin-button--primary" %>
    </div>
  </div>
<% end %>
