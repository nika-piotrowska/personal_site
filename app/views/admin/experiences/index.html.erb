<div class="d-flex justify-content-between align-items-center mb-4">
  <div>
    <h2 class="mb-1">Experience</h2>
    <p class="text-muted mb-0">Mock list of work experience entries.</p>
  </div>

  <%= link_to 'New entry', new_admin_experience_path, class: 'btn btn-primary' %>
</div>

<div class="card">
  <div class="table-responsive">
    <table class="table mb-0 align-middle">
      <thead>
        <tr>
          <th>Position</th>
          <th>Company</th>
          <th>Period</th>
          <th></th>
        </tr>
      </thead>
      <tbody>
        <tr>
          <td>Ruby on Rails Developer</td>
          <td>Company One</td>
          <td>2023 — Present</td>
          <td class="text-end">
            <%= link_to 'Show', admin_experience_path(1), class: 'btn btn-sm btn-outline-secondary' %>
            <%= link_to 'Edit', edit_admin_experience_path(1), class: 'btn btn-sm btn-outline-primary' %>
          </td>
        </tr>
      </tbody>
    </table>
  </div>
</div>
