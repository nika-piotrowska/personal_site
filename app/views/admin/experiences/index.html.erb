<div class="admin-page-header">
  <div>
    <h2 class="admin-page-header__title">Experiences</h2>
    <p class="admin-page-header__description">
      Manage your work experience entries.
    </p>
  </div>

  <div>
    <%= link_to "New experience", new_admin_experience_path, class: "admin-button admin-button--primary" %>
  </div>
</div>

<% if @experiences.any? %>
  <div class="admin-table-wrapper">
    <table class="admin-table">
      <thead>
        <tr>
          <th>Position</th>
          <th>Company</th>
          <th>Start date</th>
          <th>End date</th>
          <th></th>
        </tr>
      </thead>
      <tbody>
        <% @experiences.each do |experience| %>
          <tr>
            <td><%= experience.position %></td>
            <td><%= experience.company %></td>
            <td><%= experience.start_date || "—" %></td>
            <td><%= experience.end_date || "—" %></td>
            <td class="admin-table__actions">
              <%= link_to "Show", admin_experience_path(experience), class: "admin-button" %>
              <%= link_to "Edit", edit_admin_experience_path(experience), class: "admin-button" %>
              <%= link_to "Delete",
                          admin_experience_path(experience),
                          data: { turbo_method: :delete, turbo_confirm: "Are you sure?" },
                          class: "admin-button admin-button--danger" %>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
<% else %>
  <div class="admin-card">
    <div class="admin-card__body">
      <p>No experiences added yet.</p>
      <%= link_to "Create first experience", new_admin_experience_path, class: "admin-button admin-button--primary" %>
    </div>
  </div>
<% end %>
