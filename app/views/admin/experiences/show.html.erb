<div class="d-flex justify-content-between align-items-center mb-4">
  <div>
    <h2 class="mb-1">Experience details</h2>
    <p class="text-muted mb-0">Mock preview of a single experience entry.</p>
  </div>

  <%= link_to 'Edit entry', edit_admin_experience_path(params[:id]), class: 'btn btn-primary' %>
</div>

<div class="card">
  <div class="card-body">
    <dl class="row mb-0">
      <dt class="col-sm-3">Position</dt>
      <dd class="col-sm-9">Ruby on Rails Developer</dd>

      <dt class="col-sm-3">Company</dt>
      <dd class="col-sm-9">Company One</dd>

      <dt class="col-sm-3">Period</dt>
      <dd class="col-sm-9">2023 — Present</dd>

      <dt class="col-sm-3">Description</dt>
      <dd class="col-sm-9">Mock description of responsibilities and achievements.</dd>
    </dl>
  </div>
</div>
