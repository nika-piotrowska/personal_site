<div class="admin-page-header">
  <div>
    <h2 class="admin-page-header__title"><%= @experience.position %></h2>
    <p class="admin-page-header__description">
      Experience details.
    </p>
  </div>

  <div class="admin-page-header__actions">
    <%= link_to "Edit", edit_admin_experience_path(@experience), class: "admin-button admin-button--primary" %>
    <%= link_to "Back", admin_experiences_path, class: "admin-button" %>
  </div>
</div>

<div class="admin-card">
  <div class="admin-card__body">
    <dl class="admin-details">
      <div class="admin-details__row">
        <dt>Position</dt>
        <dd><%= @experience.position.presence || "—" %></dd>
      </div>

      <div class="admin-details__row">
        <dt>Company</dt>
        <dd><%= @experience.company.presence || "—" %></dd>
      </div>

      <div class="admin-details__row">
        <dt>Start date</dt>
        <dd><%= @experience.start_date || "—" %></dd>
      </div>

      <div class="admin-details__row">
        <dt>End date</dt>
        <dd><%= @experience.end_date || "—" %></dd>
      </div>

      <div class="admin-details__row admin-details__row--stacked">
        <dt>Description</dt>
        <dd><%= simple_format(@experience.description.presence || "—") %></dd>
      </div>
    </dl>
  </div>
</div>
