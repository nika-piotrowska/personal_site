<div class="admin-page-header">
  <div>
    <h2 class="admin-page-header__title"><%= @project.title %></h2>
    <p class="admin-page-header__description">
      Project details and metadata.
    </p>
  </div>

  <div class="admin-page-header__actions">
    <%= link_to "Edit", edit_admin_project_path(@project.slug), class: "admin-button admin-button--primary" %>
    <%= link_to "Back", admin_projects_path, class: "admin-button" %>
  </div>
</div>

<div class="admin-card">
  <div class="admin-card__body">
    <dl class="admin-details">
      <div class="admin-details__row">
        <dt>Title</dt>
        <dd><%= @project.title.presence || "—" %></dd>
      </div>

      <div class="admin-details__row">
        <dt>Slug</dt>
        <dd><%= @project.slug.presence || "—" %></dd>
      </div>

      <div class="admin-details__row">
        <dt>Short description</dt>
        <dd><%= @project.short_description.presence || "—" %></dd>
      </div>

      <div class="admin-details__row admin-details__row--stacked">
        <dt>Description</dt>
        <dd><%= simple_format(@project.description.presence || "—") %></dd>
      </div>

      <div class="admin-details__row">
        <dt>Tech stack</dt>
        <dd><%= @project.tech_stack.presence || "—" %></dd>
      </div>

      <div class="admin-details__row">
        <dt>Repository URL</dt>
        <dd>
          <% if @project.repo_url.present? %>
            <%= link_to @project.repo_url, @project.repo_url, target: "_blank", rel: "noopener" %>
          <% else %>
            —
          <% end %>
        </dd>
      </div>

      <div class="admin-details__row">
        <dt>Live URL</dt>
        <dd>
          <% if @project.live_url.present? %>
            <%= link_to @project.live_url, @project.live_url, target: "_blank", rel: "noopener" %>
          <% else %>
            —
          <% end %>
        </dd>
      </div>

      <div class="admin-details__row">
        <dt>Published</dt>
        <dd><%= @project.published? ? "Yes" : "No" %></dd>
      </div>

      <div class="admin-details__row">
        <dt>Featured</dt>
        <dd><%= @project.featured? ? "Yes" : "No" %></dd>
      </div>

      <div class="admin-details__row">
        <dt>Position</dt>
        <dd><%= @project.position || "—" %></dd>
      </div>
    </dl>
  </div>
</div>
