<div class="admin-page-header">
  <div>
    <h2 class="admin-page-header__title">Projects</h2>
    <p class="admin-page-header__description">
      Manage portfolio projects displayed on the website.
    </p>
  </div>

  <div>
    <%= link_to "New project", new_admin_project_path, class: "admin-button admin-button--primary" %>
  </div>
</div>

<% if @projects.any? %>
  <div class="admin-table-wrapper">
    <table class="admin-table">
      <thead>
        <tr>
          <th>Title</th>
          <th>Published</th>
          <th>Featured</th>
          <th>Position</th>
          <th></th>
        </tr>
      </thead>
      <tbody>
        <% @projects.each do |project| %>
          <tr>
            <td><%= project.title %></td>
            <td><%= project.published? ? "Yes" : "No" %></td>
            <td><%= project.featured? ? "Yes" : "No" %></td>
            <td><%= project.position %></td>
            <td class="admin-table__actions">
              <%= link_to "Show", admin_project_path(project.slug), class: "admin-button" %>
              <%= link_to "Edit", edit_admin_project_path(project.slug), class: "admin-button" %>
              <%= link_to "Delete",
                          admin_project_path(project.slug),
                          data: { turbo_method: :delete, turbo_confirm: "Are you sure?" },
                          class: "admin-button admin-button--danger" %>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
<% else %>
  <div class="admin-card">
    <div class="admin-card__body">
      <p>No projects added yet.</p>
      <%= link_to "Create first project", new_admin_project_path, class: "admin-button admin-button--primary" %>
    </div>
  </div>
<% end %>
