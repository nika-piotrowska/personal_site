<div class="d-flex justify-content-between align-items-center mb-4">
  <div>
    <h2 class="mb-1">Projects</h2>
    <p class="text-muted mb-0">Mock list of portfolio projects.</p>
  </div>

  <%= link_to 'New project', new_admin_project_path, class: 'btn btn-primary' %>
</div>

<div class="card">
  <div class="table-responsive">
    <table class="table mb-0 align-middle">
      <thead>
        <tr>
          <th>Title</th>
          <th>Status</th>
          <th>Featured</th>
          <th>Position</th>
          <th></th>
        </tr>
      </thead>
      <tbody>
        <tr>
          <td>Personal Site CMS</td>
          <td><span class="badge text-bg-success">Published</span></td>
          <td>Yes</td>
          <td>1</td>
          <td class="text-end">
            <%= link_to 'Show', admin_project_path(1), class: 'btn btn-sm btn-outline-secondary' %>
            <%= link_to 'Edit', edit_admin_project_path(1), class: 'btn btn-sm btn-outline-primary' %>
          </td>
        </tr>

        <tr>
          <td>Tor Exit Nodes API</td>
          <td><span class="badge text-bg-secondary">Draft</span></td>
          <td>No</td>
          <td>2</td>
          <td class="text-end">
            <%= link_to 'Show', admin_project_path(2), class: 'btn btn-sm btn-outline-secondary' %>
            <%= link_to 'Edit', edit_admin_project_path(2), class: 'btn btn-sm btn-outline-primary' %>
          </td>
        </tr>
      </tbody>
    </table>
  </div>
</div>
