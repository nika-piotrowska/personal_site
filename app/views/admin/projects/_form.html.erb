<form>
  <div class="mb-3">
    <label class="form-label">Title</label>
    <input type="text" class="form-control" value="Personal Site CMS" disabled>
  </div>

  <div class="mb-3">
    <label class="form-label">Slug</label>
    <input type="text" class="form-control" value="personal-site-cms" disabled>
  </div>

  <div class="mb-3">
    <label class="form-label">Short description</label>
    <input type="text" class="form-control" value="Portfolio website with admin panel" disabled>
  </div>

  <div class="mb-3">
    <label class="form-label">Description</label>
    <textarea class="form-control" rows="5" disabled>Mock description</textarea>
  </div>

  <div class="mb-3">
    <label class="form-label">Tech stack</label>
    <input type="text" class="form-control" value="Ruby on Rails, PostgreSQL" disabled>
  </div>

  <div class="row">
    <div class="col-md-6 mb-3">
      <label class="form-label">Repository URL</label>
      <input type="text" class="form-control" value="https://github.com/example/repo" disabled>
    </div>

    <div class="col-md-6 mb-3">
      <label class="form-label">Live URL</label>
      <input type="text" class="form-control" value="https://example.com" disabled>
    </div>
  </div>

  <div class="row">
    <div class="col-md-4 mb-3">
      <label class="form-label">Position</label>
      <input type="number" class="form-control" value="1" disabled>
    </div>

    <div class="col-md-4 mb-3">
      <label class="form-label">Published</label>
      <input type="text" class="form-control" value="true" disabled>
    </div>

    <div class="col-md-4 mb-3">
      <label class="form-label">Featured</label>
      <input type="text" class="form-control" value="true" disabled>
    </div>
  </div>

  <button type="button" class="btn btn-primary" disabled>Save project</button>
</form>
