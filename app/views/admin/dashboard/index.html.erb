<div class="d-flex justify-content-between align-items-center mb-4">
  <div>
    <h2 class="mb-1">Dashboard</h2>
    <p class="text-muted mb-0">Manage your portfolio content.</p>
  </div>
</div>

<div class="row g-4">
  <div class="col-md-4">
    <div class="card h-100">
      <div class="card-body">
        <h3 class="h5">Profile</h3>
        <p class="text-muted">Edit your personal information and bio.</p>
        <%= link_to 'View profile', admin_profile_path, class: 'btn btn-outline-primary' %>
      </div>
    </div>
  </div>

  <div class="col-md-4">
    <div class="card h-100">
      <div class="card-body">
        <h3 class="h5">Projects</h3>
        <p class="text-muted">Preview future project management screens.</p>
        <%= link_to 'View projects', admin_projects_path, class: 'btn btn-outline-primary' %>
      </div>
    </div>
  </div>

  <div class="col-md-4">
    <div class="card h-100">
      <div class="card-body">
        <h3 class="h5">Experience</h3>
        <p class="text-muted">Preview future experience management screens.</p>
        <%= link_to 'View experience', admin_experiences_path, class: 'btn btn-outline-primary' %>
      </div>
    </div>
  </div>
</div>
