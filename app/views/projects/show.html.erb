<section class="page-section">
  <%= link_to t(".back"), projects_path, class: "text-link" %>

  <article class="content-card content-card--large">
    <p class="section-label"><%= t(".label") %></p>
    <h1><%= @project.title %></h1>

    <p class="page-intro"><%= @project.short_description %></p>

    <% if @project.tech_stack.present? %>
      <p class="card-meta">
        <strong><%= t("common.stack") %></strong> <%= @project.tech_stack %>
      </p>
    <% end %>

    <% if @project.description.present? %>
      <div class="project-description">
        <%= simple_format(@project.description) %>
      </div>
    <% end %>

    <div class="project-links">
      <% if @project.repo_url.present? %>
        <%= link_to t("common.repository"), @project.repo_url, target: "_blank", rel: "noopener", class: "text-link" %>
      <% end %>

      <% if @project.live_url.present? %>
        <%= link_to t("common.live_demo"), @project.live_url, target: "_blank", rel: "noopener", class: "text-link" %>
      <% end %>
    </div>
  </article>
</section>
