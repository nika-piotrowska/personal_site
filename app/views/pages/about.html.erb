<section class="page-section">
  <p class="section-label"><%= t(".label") %></p>
  <h1><%= t(".title") %></h1>

  <% if @profile.present? %>
    <div class="content-card">
      <p><%= simple_format(@profile.bio) %></p>

      <div class="profile-links">
        <% if external_link_to(@profile.github_url).present? %>
          <p>
            <strong><%= t(".github") %></strong>
            <%= external_link_to(@profile.github_url) %>
          </p>
        <% end %>

        <% if external_link_to(@profile.linkedin_url).present? %>
          <p>
            <strong><%= t(".linkedin") %></strong>
            <%= external_link_to(@profile.linkedin_url) %>
          </p>
        <% end %>

        <% if @profile.location.present? %>
          <p>
            <strong><%= t(".location") %></strong>
            <%= @profile.location %>
          </p>
        <% end %>
      </div>
    </div>
  <% else %>
    <p><%= t("common.profile_unavailable") %></p>
  <% end %>
</section>
