<section class="page-section">
  <p class="section-label">About</p>
  <h1>About me</h1>

  <% if @profile.present? %>
    <div class="content-card">
      <p><%= simple_format(@profile.bio) %></p>

      <div class="profile-links">
        <% if external_link_to(@profile.github_url).present? %>
          <p>
            <strong>GitHub:</strong>
            <%= external_link_to(@profile.github_url) %>
          </p>
        <% end %>

        <% if external_link_to(@profile.linkedin_url).present? %>
          <p>
            <strong>LinkedIn:</strong>
            <%= external_link_to(@profile.linkedin_url) %>
          </p>
        <% end %>

        <% if @profile.email.present? %>
          <p>
            <strong>Email:</strong>
            <%= mail_to @profile.email %>
          </p>
        <% end %>

        <% if @profile.location.present? %>
          <p>
            <strong>Location:</strong>
            <%= @profile.location %>
          </p>
        <% end %>
      </div>
    </div>
  <% else %>
    <p>Profile data is not available yet.</p>
  <% end %>
</section>
