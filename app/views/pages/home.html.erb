<section class="page-section">
  <p class="section-label"><%= t(".welcome") %></p>

  <% if @profile.present? %>
    <h1><%= @profile.headline %></h1>

    <p class="page-intro">
      <%= @profile.bio %>
    </p>

    <div class="profile-meta">
      <% if @profile.location.present? %>
        <span><%= @profile.location %></span>
      <% end %>

      <span><%= mail_to @profile.email %></span>
    </div>
  <% else %>
    <h1><%= t(".fallback_title") %></h1>
    <p class="page-intro"><%= t("common.profile_unavailable") %></p>
  <% end %>
</section>

<section class="page-section">
  <div class="section-header">
    <div>
      <p class="section-label"><%= t(".projects_label") %></p>
      <h2><%= t(".featured_work") %></h2>
    </div>

    <%= link_to t("common.view_all"), projects_path, class: "text-link" %>
  </div>

  <% if @featured_projects.any? %>
    <div class="projects-grid">
      <%= render partial: 'projects/project_card', collection: @featured_projects, as: :project %>
    </div>
  <% else %>
    <p><%= t(".no_featured_projects") %></p>
  <% end %>
</section>

<section class="page-section">
  <div class="section-header">
    <div>
      <p class="section-label"><%= t(".experience_label") %></p>
      <h2><%= t(".recent_roles") %></h2>
    </div>

    <%= link_to t("common.view_all"), experience_path, class: "text-link" %>
  </div>

  <% if @recent_experiences.any? %>
    <div class="content-list">
      <%= render partial: 'pages/experience_card', collection: @recent_experiences, as: :experience %>
    </div>
  <% else %>
    <p><%= t(".no_experience") %></p>
  <% end %>
</section>
